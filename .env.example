# Firebase web app config. Copy this file to `.env.local` and fill in the values
# from the Firebase console: Project settings → General → Your apps → SDK setup
# and configuration (Config). These values are public — they ship to the browser —
# access is controlled by Firebase Auth + Firestore security rules, not secrecy.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary image uploads. Create a free account, then in the console:
# Settings → Upload → Upload presets → add an UNSIGNED preset.
# The cloud name is shown on the dashboard (Settings → Account / API keys).
# Both values are public (an unsigned preset is designed for browser uploads).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
