rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Gallery posts: anyone may read (public gallery); only authenticated
    // backoffice users may create, edit, or delete.
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else is locked down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
